graphUniform
{
    type            sets;
    libs            ("libsampling.so");
    
    writeControl    timeStep;
    writeInterval   100;
    
    interpolationScheme cellPoint;
    
    setFormat       raw;
    
    sets
    {
        line
        {
            type            lineUniform;
            axis            z;
            start           (0 0 -0.8);
            end             (0 0 -4);
            nPoints         300;
        }
    }
    
    fields          (p);
}
