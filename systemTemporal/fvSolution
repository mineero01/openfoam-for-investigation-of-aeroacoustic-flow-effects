FoamFile
{
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    "rho.*"
    {
        solver          diagonal;
    }

    p
    {
/*
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-9;
        relTol          0.001;*/

        solver          GAMG;
        tolerance       1e-08;
        relTol          0.05;
        smoother        GaussSeidel;
        nCellsInCoarsestLevel 1500;

  }

    pFinal
    {
        $p;
        relTol          0;
    }

    "(U|k|epsilon|omega|e)"
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-9;
        relTol          0.001;
        minIter 1;
    }

    

    "(U|k|epsilon|omega|e)Final"
    {

        $U;
        relTol          0;
    }
    
    "pcorr.*"
    {
        solver          PCG;
        preconditioner  DIC;
        tolerance       1e-2;
        maxIter         200;
        relTol          0;
    }
}

PIMPLE
{
    transonic           no;

    nCorrectors         2;
    nNonOrthogonalCorrectors 3;

    correctPhi          yes;
    correctMeshPhi      no;
    checkMeshCourantNo  yes;
}

relaxationFactors
{
    equations
    {
        ".*"        1;
    }
}




