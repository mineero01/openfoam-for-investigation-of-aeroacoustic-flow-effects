FoamFile
{
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     foamRun;

solver          fluid;

startFrom       latestTime;

startTime       0;

stopAt          endTime;

endTime         4;

deltaT          0.00001;

writeControl    adjustableRunTime;  // or timeStep

adjustTimeStep  yes;  // Optional, for automatic time step adjustment

maxCo           1;     // Maximum Courant number

writeInterval   0.1;

purgeWrite      0;

writeFormat     binary;

writePrecision  6;

writeCompression off;

timeFormat      general;

timePrecision   6;

runTimeModifiable true;

OptimisationSwitches
{
    fileHandler     collated;
    maxThreadFileBufferSize 0;
}

