FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0";
    object      T;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 1 0 0 0];

internalField   uniform 623.15; //350C As in the acoustics simulations

boundaryField
{
    inlet
    {
        type            inletOutlet;
        inletValue      uniform 623.15;
        value           uniform 623.15;
    }

    outlet
    {
        type            inletOutlet;
        inletValue      uniform 623.15;
        value           uniform 623.15;
    }

    walls
    {
        type            zeroGradient;
    }
}

