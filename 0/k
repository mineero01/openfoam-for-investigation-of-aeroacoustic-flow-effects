FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0";
    object      k;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -2 0 0 0 0];

internalField   uniform X; //Calculated based on mean velocity and turbulence intensity estimated at I=0.1

boundaryField
{
    inlet
    {
        type            turbulentIntensityKineticEnergyInlet;
        intensity       0.1;
        value           $internalField;
    }

    outlet
    {
        type            turbulentIntensityKineticEnergyInlet;
        intensity       0.1;
        value           $internalField;
    }

    walls
    {
        type            kqRWallFunction;
        value           uniform 0;
    }
}

