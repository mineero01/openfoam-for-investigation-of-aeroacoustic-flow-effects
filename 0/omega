FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0";
    object      omega;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 -1 0 0 0 0];

internalField   uniform X;	//Calculated based on diameter of inlet and k

boundaryField
{
    inlet
    {
        type            turbulentMixingLengthFrequencyInlet;
        mixingLength    X; //Calculated based on diameter * 0.07
        value           $internalField;
    }

    outlet
    {
        type            turbulentMixingLengthFrequencyInlet;
        mixingLength    X; //Calculated based on diameter * 0.07
        value           $internalField;
    }

    walls
    {
        type            omegaWallFunction;
        Cmu             0.09;
        kappa           0.41;
        E               9.8;
        value           uniform 0;
    }
}

