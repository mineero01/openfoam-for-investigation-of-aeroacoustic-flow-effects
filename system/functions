FoamFile
{
    format      ascii;
    class       dictionary;
    location    "system";
    object      functions;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
//NOTE: functions were only ran when needed.

residuals
{
    type            residuals;
    libs            ("libutilityFunctionObjects.so");
    writeControl    timeStep;
    writeInterval   1;
    fields          (p U k omega);
}
yPlus1
{
    type            yPlus;
    libs            ("libfieldFunctionObjects.so");
    writeControl    writeTime;
    log             true;
}
turbulenceIntensity
{

    type        turbulenceIntensity;
    libs        ("libfieldFunctionObjects.so");
    
    writeControl writeTime;     // When to write results
    
    
    // Output options
    log         true;          // Write to log
    writeFields true;          // Write fields to disk
}
