FoamFile
{
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{   
    rho
    {
        solver          diagonal;
    }

    p
    {
        solver          GAMG;
        tolerance       1e-08;
        relTol          0.05;
        smoother        GaussSeidel;
        nCellsInCoarsestLevel 1500;
    }

    pFinal
    {
        $p;
        relTol          0;
    }

    "(U|k|epsilon|omega|f|v2|e)"
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-9;
        relTol          0.001;
        minIter 1;
    }
    "(U|k|epsilon|omega|f|v2|e)Final"
    {

        $U;
        relTol          0;
    }
    
    pcorr
    {
        solver          PCG;
        preconditioner  DIC;
        tolerance       1e-2; //Changed from 1e-2 to 1e-3
        maxIter         200;
        relTol          0;
    }
}

SIMPLE
{
    nNonOrthogonalCorrectors 3;
    consistent      yes;
    correctPhi      yes;
    residualControl
    {
        p               1e-4;
        U               1e-4;
        "(k|epsilon|omega|f|v2)" 1e-4;
    }
}

relaxationFactors
{
    equations
    {
        
        //U               0.7; 
        ".*"            0.9; 
    }
    fields
    {
    
    }
}


